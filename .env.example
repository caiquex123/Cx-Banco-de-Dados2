# Variáveis de ambiente do CxIA

# ==================== BACKEND (DATABASE) ====================
# URL do seu banco de dados local (seu PC rodando 24h)
# Exemplo local: http://localhost:8000
# Exemplo com IP fixo: http://192.168.1.100:8000
# Exemplo com domínio: https://api.meusite.com
VITE_DATABASE_URL=http://localhost:8000

# ==================== FIREBASE (MANTER PARA AUTH GOOGLE) ====================
# Copiar do console do Firebase
VITE_FIREBASE_API_KEY=sua_api_key
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_project_id
VITE_FIREBASE_STORAGE_BUCKET=seu_bucket.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id
VITE_FIREBASE_APP_ID=seu_app_id

# ==================== API DE IA ====================
# Chave da DeepSeek API
DEEPSEEK_API_KEY=sua_deepseek_api_key

# Chave da Gemini API (fallback)
GEMINI_API_KEY=sua_gemini_api_key

# ==================== OUTRAS ====================
# Porta do servidor de desenvolvimento
PORT=3000
